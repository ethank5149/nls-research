\begin_inset Formula $y_{1}$
\end_inset

 lies along 
\begin_inset Formula $\boldsymbol{r_{2}}$
\end_inset

 by convention.
 We can then write
\begin_inset Formula 
\begin{align*}
y_{1}^{\prime} & =\left(0,h\right)^{\intercal} & y_{2}^{\prime} & =\left(-a,-\frac{h}{2}\right)^{\intercal} & y_{3}^{\prime} & =\left(a,-\frac{h}{2}\right)^{\intercal}\\
 & =h\boldsymbol{r_{2}} &  & =-a\boldsymbol{r_{1}}-\left(\frac{h}{2}\right)\boldsymbol{r_{2}} &  & =a\boldsymbol{r_{1}}-\left(\frac{h}{2}\right)\boldsymbol{r_{2}}
\end{align*}

\end_inset

such that
\begin_inset Formula 
\[
\left\{ \begin{array}{c}
2a=1\\
a^{2}+\left(\frac{3h}{2}\right)^{2}=1
\end{array}\right.\Longrightarrow\left\{ \begin{array}{c}
a=\frac{1}{2}\\
\left(\frac{3h}{2}\right)^{2}=1-a^{2}
\end{array}\right.\Longrightarrow\left\{ \begin{array}{c}
a=\frac{1}{2}\\
h=\frac{1}{\sqrt{3}}
\end{array}\right.
\]

\end_inset

as well as
\begin_inset Formula 
\begin{align*}
y_{1} & =R\left(\theta\right)y_{1}^{\prime}=\begin{pmatrix}-h\sin\theta\\
h\cos\theta
\end{pmatrix}=-h\sin\left(\theta\right)\boldsymbol{r_{1}}+h\cos\left(\theta\right)\boldsymbol{r_{2}}\\
y_{2} & =R\left(\theta\right)y_{2}^{\prime}=\begin{pmatrix}-a\cos\theta+\left(\frac{h}{2}\right)\sin\theta\\
-a\sin\theta-\left(\frac{h}{2}\right)\cos\theta
\end{pmatrix}=\left(-a\cos\theta+\left(\frac{h}{2}\right)\sin\theta\right)\boldsymbol{r_{1}}-\left(a\sin\theta+\left(\frac{h}{2}\right)\cos\theta\right)\boldsymbol{r_{2}}\\
y_{3} & =R\left(\theta\right)y_{3}^{\prime}=\begin{pmatrix}a\cos\theta+\left(\frac{h}{2}\right)\sin\theta\\
a\sin\theta-\left(\frac{h}{2}\right)\cos\theta
\end{pmatrix}=\left(a\cos\theta+\left(\frac{h}{2}\right)\sin\theta\right)\boldsymbol{r_{1}}+\left(a\sin\theta-\left(\frac{h}{2}\right)\cos\theta\right)\boldsymbol{r_{2}}
\end{align*}

\end_inset

Now 
\begin_inset Formula 
\begin{align*}
H_{V}y_{1} & =\alpha_{12}\left(y_{2}-y_{1}\right)+\alpha_{13}\left(y_{3}-y_{1}\right)\\
H_{V}R\left(\theta\right)y_{1}^{\prime} & =\\
R^{-1}\left(\theta\right)H_{V}R\left(\theta\right)y_{1}^{\prime} & =\alpha_{12}\left(y_{2}^{\prime}-y_{1}^{\prime}\right)+\alpha_{13}\left(y_{3}^{\prime}-y_{1}^{\prime}\right)\\
 & \Downarrow\\
\alpha_{12}\begin{pmatrix}-a\\
-\frac{3h}{2}
\end{pmatrix}+\alpha_{13}\begin{pmatrix}a\\
-\frac{3h}{2}
\end{pmatrix} & =\begin{pmatrix}\lambda_{2}\sin^{2}\theta+\lambda_{1}\cos^{2}\theta & \left(\lambda_{2}-\lambda_{1}\right)\sin\theta\cos\theta\\
\left(\lambda_{2}-\lambda_{1}\right)\sin\theta\cos\theta & \lambda_{2}\cos^{2}\theta+\lambda_{1}\sin^{2}\theta
\end{pmatrix}\begin{pmatrix}0\\
h
\end{pmatrix}\\
\begin{pmatrix}\alpha_{13}-\alpha_{12}\\
\alpha_{13}+\alpha_{12}
\end{pmatrix} & =\begin{pmatrix}\frac{h}{a}\left(\lambda_{2}-\lambda_{1}\right)\sin\theta\cos\theta\\
-\frac{2}{3}\left(\lambda_{2}\cos^{2}\theta+\lambda_{1}\sin^{2}\theta\right)
\end{pmatrix}\\
