\begin_inset Formula 
\[
\Downarrow
\]

\end_inset


\begin_inset Formula 
\[
\begin{cases}
\sin^{2}\theta+\mu\cos^{2}\theta+\sqrt{3}\left(\mu-1\right)\sin\theta\cos\theta & \geq0\quad\left(\text{I}\right)\\
\sin^{2}\theta+\mu\cos^{2}\theta-\sqrt{3}\left(\mu-1\right)\sin\theta\cos\theta & \geq0\quad\left(\text{II}\right)\\
