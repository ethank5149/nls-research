;
 
\begin_inset Formula $H_{V}\boldsymbol{r_{i}}=\lambda_{i}\boldsymbol{r_{i}},\lambda_{i}<0,\left|\boldsymbol{r_{i}}\right|=1\,\forall i=1,2$
\end_inset

.
