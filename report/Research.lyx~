\begin_layout Standard
We wish to study the following nonlinear (time independent) Schrodinger equation (NLS)
\begin_inset Formula 
\begin{equation}
\left(-\Delta+V+E\right)\psi+\sigma\left|\psi\right|^{2p}\psi=0\label{eq:NLS-background}
\end{equation}

\end_inset

for 
\begin_inset Formula $V:\mathbb{R}^{n}\to\mathbb{R},\,\psi:\mathbb{R}^{n}\to\mathbb{C}$
\end_inset

 with 
\begin_inset Formula $\sigma\in\mathbb{R}^{+},\,E\in\mathbb{R}^{+}\cup\left\{ 0\right\} $
\end_inset

.
 For each value of the energy 
\begin_inset Formula $E$
\end_inset

,
 we denote solutions of 
\begin_inset CommandInset ref
LatexCommand eqref
reference "eq:NLS-background"
plural "false"
caps "false"
noprefix "false"
nolink "false"

\end_inset

 as 
\begin_inset Formula $\psi_{E}$
\end_inset

.
 Let 
\begin_inset Formula $x\in\mathbb{R}^{n}$
\end_inset

,
 consider 
\begin_inset Formula 
\begin{align}
u_{E}\left(x\right) & =E^{-\frac{1}{2p}}\psi_{E}\left(E^{-\frac{1}{2}}x\right),\label{eq:rescaling}
\end{align}

\end_inset

from 
\begin_inset CommandInset citation
LatexCommand cite
key "KirrNatarajan2018"
literal "false"

\end_inset

 such that 
\begin_inset Formula 
\[
\left\Vert u_{E}\right\Vert _{H^{1}}^{2}=\left\Vert \nabla\psi_{E}\right\Vert _{L^{2}}^{2}+\left\Vert \psi_{E}\right\Vert _{L^{2}}^{2}
\]

\end_inset

remains bounded.
 By concentration compactness,
 there exists 
\begin_inset Formula $M\in\mathbb{N}$
\end_inset

 such that 
\begin_inset Formula 
\begin{equation}
\left\Vert u_{E}\left(x\right)-\sum_{i=1}^{M}u_{i}\left(x-z_{i}\left(E\right)\right)\right\Vert _{H^{1}}\xrightarrow{E\to\infty}0,\label{eq:concentration}
\end{equation}

\end_inset

where 
\begin_inset Formula $u_{i}:\mathbb{R}^{n}\to\mathbb{C}$
\end_inset

