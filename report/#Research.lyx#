\end_layout

\begin_layout Proposition
\begin_inset Argument 1
status collapsed

\begin_layout Plain Layout
Center-of-mass identity
\end_layout

\end_inset


\begin_inset CommandInset label
LatexCommand label
name "prop:sum-Fi"

\end_inset

 For any 
\begin_inset Formula $\delta y=(\delta y_{1},\delta y_{2},\delta y_{3})$
\end_inset

 and any 
\begin_inset Formula $R\geq0$
\end_inset

,
 
\begin_inset Formula 
\begin{equation}
\sum_{i=1}^{3}F_{i}(\delta y,R)=\HV\frac{\sum_{i}\delta y_{i}}{\tilde{m}_{R}}\,.\label{eq:sum-Fi-identity}
\end{equation}

\end_inset

In particular,
 
\begin_inset Formula $\sum_{i}F_{i}=0$
\end_inset

 if and only if 
\begin_inset Formula $\sum_{i}\delta y_{i}=0$
\end_inset

 (the center-of-mass condition).
 The explicit solution 
\begin_inset Formula $\delta y^{0}$
\end_inset

 of Proposition
\begin_inset space ~
\end_inset

4.1 satisfies this condition,
 and the gauge-fixing constraints 
\shape up
(G1)–(G2)
\shape default
 are compatible with
\begin_inset space ~
\end_inset


\begin_inset Formula $\delta y^{0}$
\end_inset

.
 
\end_layout

\begin_layout Proof
The interaction terms in 
\begin_inset Formula $F_{i}$
\end_inset

 (Definition
\begin_inset space ~
\end_inset

4.1) involve differences 
\begin_inset Formula $(y_{k}-y_{i})$
\end_inset

 and 
\begin_inset Formula $(\delta y_{k}-\delta y_{i})/\tilde{m}_{R}$
\end_inset

.
 Each nearest-neighbor edge 
\begin_inset Formula $\{i,k\}$
\end_inset

 contributes to 
\begin_inset Formula $\sum_{i}F_{i}$
\end_inset

 through both the 
\begin_inset Formula $F_{i}$
\end_inset

 summand (with factor 
\begin_inset Formula $y_{k}-y_{i}+(\delta y_{k}-\delta y_{i})/\tilde{m}_{R}$
\end_inset

) and the 
\begin_inset Formula $F_{k}$
\end_inset

 summand (with factor 
\begin_inset Formula $y_{i}-y_{k}+(\delta y_{i}-\delta y_{k})/\tilde{m}_{R}$
\end_inset

).
 Since the scalar coefficient 
\begin_inset Formula $\frac{2Q_{R}(|\tilde{y}_{k}-\tilde{y}_{i}|)}{\norm{u_{R}}_{L^{2}}^{2}R^{4}|\tilde{y}_{k}-\tilde{y}_{i}|}$
\end_inset

 depends only on 
\begin_inset Formula $|\tilde{y}_{k}-\tilde{y}_{i}|=|\tilde{y}_{i}-\tilde{y}_{k}|$
\end_inset

,
 these contributions are equal in magnitude and opposite in sign;
 hence they cancel.
\end_layout

\begin_layout Proof
What remains from the Hessian terms is 
\begin_inset Formula 
\[
\sum_{i=1}^{3}F_{i}(\delta y,R)=\sum_{i=1}^{3}\Bigl[\HV y_{i}+\HV\frac{\delta y_{i}}{\tilde{m}_{R}}\Bigr]=\HV\frac{\sum_{i}\bigl(\tilde{m}_{R}\,y_{i}+\delta y_{i}\bigr)}{\tilde{m}_{R}}\,.
\]

\end_inset

For the equilateral triangle,
 
\begin_inset Formula $\sum_{i}y_{i}=0$
\end_inset

 by symmetry (the centroid is at the origin),
 so 
\begin_inset Formula $\sum_{i}F_{i}=\HV\,\bigl(\sum_{i}\delta y_{i}\bigr)/\tilde{m}_{R}$
\end_inset

.
 Since 
\begin_inset Formula $\HV$
\end_inset

 is invertible (Hypothesis
\begin_inset space ~
\end_inset

V3),
 
\begin_inset Formula $\sum_{i}F_{i}=0$
\end_inset

 if and only if 
\begin_inset Formula $\sum_{i}\delta y_{i}=0$
\end_inset

.
\end_layout

\begin_layout Proof
\begin_inset VSpace smallskip
\end_inset

For the explicit solution:
 
\begin_inset Formula $\sum_{i}\delta y_{i}^{0}=(-\gamma\boldsymbol{r}_{2})+(-\beta\boldsymbol{r}_{1}+\tfrac{\gamma}{2}\boldsymbol{r}_{2})+(\beta\boldsymbol{r}_{1}+\tfrac{\gamma}{2}\boldsymbol{r}_{2})=\boldsymbol{0}$
\end_inset

.
\end_layout

\begin_layout Proof
\begin_inset VSpace smallskip
\end_inset

For the gauge-fixing compatibility:
 
\begin_inset Formula $\delta y_{1}^{0}=-\gamma\boldsymbol{r}_{2}$
\end_inset

 has zero 
\begin_inset Formula $\boldsymbol{r}_{1}$
\end_inset

-component,
 so 
\begin_inset Formula $\delta y_{1}^{0}\perp\boldsymbol{r}_{1}$
\end_inset

 (condition G1).
 And 
\begin_inset Formula $\delta y_{3}^{0}-\delta y_{2}^{0}=2\beta\boldsymbol{r}_{1}\parallel\boldsymbol{r}_{1}$
\end_inset

 (condition G2).
 
\end_layout

