\begin_layout Standard
We now extend the limiting configurations (
\begin_inset Formula $R=0$
\end_inset

) to exact solutions at finite energy (
\begin_inset Formula $R>0$
\end_inset

).
 We focus on the equilateral triangle at 
\begin_inset Formula $\theta=0$
\end_inset

.
\end_layout

\begin_layout Subsection
Formulation
\end_layout

\begin_layout Standard
\begin_inset CommandInset label
LatexCommand label
name "subsec:formulation"

\end_inset


\end_layout

\begin_layout Standard
Write 
\begin_inset Formula $\tilde{y}_{i}=\tilde{m}_{R}\,y_{i}+\delta y_{i}$
\end_inset

 with 
\begin_inset Formula $\delta y_{i}/\tilde{m}_{R}\to0$
\end_inset

 as 
\begin_inset Formula $R\to0$
\end_inset

,
 where 
\begin_inset Formula $\delta y_{i}\in\operatorname{span}\{\boldsymbol{r}_{1},\boldsymbol{r}_{2}\}$
\end_inset

.
\end_layout

\begin_layout Definition
\begin_inset Argument 1
status collapsed

\begin_layout Plain Layout
Perturbation system
\end_layout

\end_inset


\begin_inset CommandInset label
LatexCommand label
name "def:Fi"

\end_inset

 Define 
\begin_inset Formula 
\begin{equation}
F_{i}(\delta y,R)=\HV y_{i}+\HV\frac{\delta y_{i}}{\tilde{m}_{R}}-\sum_{k\in N_{i}}\frac{2Q_{R}\bigl(|\tilde{m}_{R}(y_{k}-y_{i})+\delta y_{k}-\delta y_{i}|\bigr)}{\norm{u_{R}}_{L^{2}}^{2}\,R^{4}\,|\tilde{m}_{R}(y_{k}-y_{i})+\delta y_{k}-\delta y_{i}|}\Bigl(y_{k}-y_{i}+\frac{\delta y_{k}-\delta y_{i}}{\tilde{m}_{R}}\Bigr).\label{eq:Fi-def}
\end{equation}

\end_inset

Extending by continuity to 
\begin_inset Formula $R=0$
\end_inset

:
 
\begin_inset Formula 
\begin{equation}
F_{i}(\delta y,0)=\HV y_{i}-\chi\sum_{k\in N_{i}}e^{-\ip{y_{k}-y_{i}}{\delta y_{k}-\delta y_{i}}}(y_{k}-y_{i}),\label{eq:Fi-zero}
\end{equation}

\end_inset

where 
\begin_inset Formula $\chi$
\end_inset

 is the overall interaction strength (Definition
\begin_inset space ~
\end_inset


\begin_inset CommandInset ref
LatexCommand ref
reference "def:chi"
plural "false"
caps "false"
noprefix "false"
nolink "false"

\end_inset

),
 and the perturbed interaction coefficients are 
\begin_inset Formula $\tilde{\alpha}_{ki}=e^{-\ip{y_{k}-y_{i}}{\delta y_{k}-\delta y_{i}}}$
\end_inset

,
 satisfying 
\begin_inset Formula $\tilde{\alpha}_{ki}\chi\to\alpha_{ki}\chi$
\end_inset

 as 
\begin_inset Formula $\delta y\to0$
\end_inset

.
 Note that the constraint 
\begin_inset Formula $\max_{k}\alpha_{ki}=1$
\end_inset

 from
\begin_inset space ~
\end_inset


\begin_inset CommandInset ref
LatexCommand eqref
reference "eq:alpha-def"
plural "false"
caps "false"
noprefix "false"
nolink "false"

\end_inset

 normalizes 
\begin_inset Formula $\chi$
\end_inset

 to equal the total force from a nearest-neighbor pair at minimum distance.
\end_layout

\begin_layout Definition
The Fréchet derivative is 
\begin_inset Formula 
\begin{equation}
D_{\delta y}F_{i}(\delta y,0)[w]=\chi\sum_{k\in N_{i}}\ip{w_{k}-w_{i}}{y_{k}-y_{i}}\,e^{-\ip{y_{k}-y_{i}}{\delta y_{k}-\delta y_{i}}}(y_{k}-y_{i}).\label{eq:Fi-deriv}
\end{equation}

\end_inset


\end_layout

\begin_layout Subsection
Explicit solution at 
\begin_inset Formula $R=0$
\end_inset


\end_layout

\begin_layout Standard
\begin_inset CommandInset label
LatexCommand label
name "subsec:explicit"

\end_inset


\end_layout

\begin_layout Proposition
\begin_inset Argument 1
status collapsed

\begin_layout Plain Layout
Explicit solution
\end_layout

\end_inset


\begin_inset CommandInset label
LatexCommand label
name "prop:explicit-soln"

\end_inset

 Define 
\begin_inset Formula $\beta=\frac{1}{2}\ln(\alpha_{12}/\alpha_{23})$
\end_inset

 and 
\begin_inset Formula $\gamma=\frac{2\beta}{3\sqrt{3}}$
\end_inset

,
 where 
\begin_inset Formula $\alpha_{12}=-\lambda_{2}/3$
\end_inset

 and 
\begin_inset Formula $\alpha_{23}=\lambda_{2}/6-\lambda_{1}/2$
\end_inset

 are the unperturbed coefficients.
 Then 
\begin_inset Formula 
\begin{equation}
\delta y_{1}^{0}=-\gamma\,\boldsymbol{r}_{2},\qquad\delta y_{2,3}^{0}=\mp\beta\,\boldsymbol{r}_{1}+\tfrac{\gamma}{2}\,\boldsymbol{r}_{2}\label{eq:delta-y0}
\end{equation}

\end_inset

solves 
\begin_inset Formula $F_{i}(\delta y,0)=0$
\end_inset

 for 
\begin_inset Formula $i=1,2,3$
\end_inset

.
 
\end_layout

\begin_layout Proof
The perturbed interaction coefficients at 
\begin_inset Formula $\delta y^{0}$
\end_inset

 are (computed by direct substitution):
 
\begin_inset Formula 
\begin{align*}
\tilde{\alpha}_{12}=\tilde{\alpha}_{13} & =e^{-\ip{y_{2}-y_{1}}{\delta y_{2}^{0}-\delta y_{1}^{0}}}=1,\\
\tilde{\alpha}_{23}=\tilde{\alpha}_{32} & =e^{-\ip{y_{3}-y_{2}}{\delta y_{3}^{0}-\delta y_{2}^{0}}}=\frac{\alpha_{23}}{\alpha_{12}}.
\end{align*}

\end_inset

The first follows from the fact that 
\begin_inset Formula $\ip{y_{2}-y_{1}}{\delta y_{2}^{0}-\delta y_{1}^{0}}=0$
\end_inset

 (which one verifies by substituting the explicit coordinates).
 The second uses 
\begin_inset Formula $\ip{y_{3}-y_{2}}{\delta y_{3}^{0}-\delta y_{2}^{0}}=2\beta=\ln(\alpha_{12}/\alpha_{23})$
\end_inset

.
\end_layout

\begin_layout Proof
Setting 
\begin_inset Formula $\chi=-\lambda_{2}/3$
\end_inset

 (the overall interaction strength from Remark
\begin_inset space ~
\end_inset


\begin_inset CommandInset ref
LatexCommand ref
reference "rmk:alpha-convention"
plural "false"
caps "false"
noprefix "false"
nolink "false"

\end_inset

,
 equal to the combined force coefficient 
\begin_inset Formula $\hat{\alpha}_{12}$
\end_inset

 of the apex–base edges),
 the system 
\begin_inset Formula $F_{i}(\delta y^{0},0)=0$
\end_inset

 becomes 
\begin_inset Formula 
\[
\HV y_{i}=\alpha_{12}\bigl[\tilde{\alpha}_{i1}(y_{1}-y_{i})+\tilde{\alpha}_{i,\text{other}}(y_{\text{other}}-y_{i})\bigr]
\]

\end_inset

for each 
\begin_inset Formula $i$
\end_inset

,
 which reduces to the original algebraic system
\begin_inset space ~
\end_inset


\begin_inset CommandInset ref
LatexCommand eqref
reference "eq:algebraic"
plural "false"
caps "false"
noprefix "false"
nolink "false"

\end_inset

.
 Substituting the known values and simplifying component-wise confirms 
\begin_inset Formula $F_{i}=0$
\end_inset

 for each 
\begin_inset Formula $i$
\end_inset

.
\end_layout

\begin_layout Proof
We also verify the center-of-mass condition:
 
\begin_inset Formula $\delta y_{1}^{0}+\delta y_{2}^{0}+\delta y_{3}^{0}=(0,0)$
\end_inset

,
 which is immediate from the definitions.
 
\end_layout

\begin_layout Subsection
Kernel of the linearization
\end_layout

\begin_layout Standard
\begin_inset CommandInset label
LatexCommand label
name "subsec:kernel"

\end_inset


\end_layout

\begin_layout Proposition
\begin_inset Argument 1
status collapsed

\begin_layout Plain Layout
Nontrivial kernel
\end_layout

\end_inset


\begin_inset CommandInset label
LatexCommand label
name "prop:kernel"

\end_inset

 The linearization 
\begin_inset Formula $D_{\delta y}F_{i}(\delta y^{0},0)$
\end_inset

 has a four-dimensional kernel 
\begin_inset Formula 
\[
\Omega=\{(w_{1},w_{2},w_{3})\in(\R^{2})^{3}:\ip{w_{k}-w_{i}}{y_{k}-y_{i}}=0\;\;\forall\,i\neq k\}.
\]

\end_inset

This kernel contains the two-dimensional translational subspace 
\begin_inset Formula $\{(v,v,v):v\in\R^{2}\}$
\end_inset

 and two additional directions,
 including the rotational mode 
\begin_inset Formula $w_{\mathrm{rot}}=\frac{d}{d\theta}y_{i}(\theta)\big|_{\theta=0}$
\end_inset

.
 
\end_layout

\begin_layout Proof
The kernel condition 
\begin_inset Formula $\ip{w_{k}-w_{i}}{y_{k}-y_{i}}=0$
\end_inset

 for all neighbor pairs gives three scalar constraints on 
\begin_inset Formula $w\in\R^{6}$
\end_inset

.
 Since 
\begin_inset Formula $y_{3}-y_{2}=(y_{3}-y_{1})-(y_{2}-y_{1})$
\end_inset

,
 only two constraints are independent,
 so 
\begin_inset Formula $\dim\Omega\geq6-2=4$
\end_inset

.
\end_layout

\begin_layout Proof
To see that 
\begin_inset Formula $\Omega\supseteq\{(v,v,v):v\in\R^{2}\}$
\end_inset

:
 if 
\begin_inset Formula $w_{1}=w_{2}=w_{3}=v$
\end_inset

,
 then 
\begin_inset Formula $w_{k}-w_{i}=0$
\end_inset

,
 so all inner products vanish.
 This is a 2D subspace.
\end_layout

\begin_layout Proof
The quadratic form argument shows the inclusion is an equality:
 define 
\begin_inset Formula 
\[
\Phi=\sum_{i}w_{i}\cdot D_{\delta y}F_{i}(\delta y^{0},0)[w]=-\chi\sum_{\{i,k\}\in\text{edges}}\alpha_{ik}\bigl(\ip{w_{k}-w_{i}}{y_{k}-y_{i}}\bigr)^{2}.
\]

\end_inset

Since 
\begin_inset Formula $\Phi\leq0$
\end_inset

 and 
\begin_inset Formula $\Phi=0$
\end_inset

 implies each summand vanishes (as 
\begin_inset Formula $\alpha_{ik}>0$
\end_inset

 for all edges of the equilateral triangle),
 the kernel is precisely 
\begin_inset Formula $\Omega$
\end_inset

.
 Computing explicitly,
 
\begin_inset Formula $\dim\Omega=4$
\end_inset

.
\end_layout

\begin_layout Proof
The rotational mode 
\begin_inset Formula $w_{\mathrm{rot}}=(\frac{d}{d\theta}y_{i}(\theta)|_{\theta=0})_{i=1,2,3}=(-h,0;\;\frac{h}{2},-a;\;\frac{h}{2},a)$
\end_inset

 lies in 
\begin_inset Formula $\Omega$
\end_inset

 since 
\begin_inset Formula $\ip{w_{\mathrm{rot},k}-w_{\mathrm{rot},i}}{y_{k}-y_{i}}=0$
\end_inset

 for all pairs (verified by direct computation).
 
\end_layout

\begin_layout Standard
\noindent
\begin_inset ERT
status collapsed

\begin_layout Plain Layout


\backslash
begin{rmk}
\end_layout

\end_inset


\begin_inset CommandInset label
LatexCommand label
name "rmk:kernel-dim-new"

\end_inset

 The four kernel dimensions decompose as follows.
 The two translational modes 
\begin_inset Formula $\{(v,v,v):v\in\R^{2}\}$
\end_inset

 span a 
\begin_inset Formula $2$
\end_inset

-dimensional subspace.
 The rotational mode 
\begin_inset Formula $w_{\mathrm{rot}}$
\end_inset

 accounts for one additional dimension.
 The remaining fourth direction is a 
\emph on
breathing mode
\emph default
:
 it corresponds to a simultaneous dilation/contraction of the triangle that preserves the kernel condition 
\begin_inset Formula $\ip{w_{k}-w_{i}}{y_{k}-y_{i}}=0$
\end_inset

.
 Explicitly,
 one can verify that 
\begin_inset Formula $w_{\mathrm{br}}=(y_{1}^{\perp},y_{2}^{\perp},y_{3}^{\perp})$
\end_inset

,
 where 
\begin_inset Formula $y_{i}^{\perp}$
\end_inset

 is the 
\begin_inset Formula $90^{\circ}$
\end_inset

 rotation of 
\begin_inset Formula $y_{i}$
\end_inset

 within the 
\begin_inset Formula $(\boldsymbol{r}_{1},\boldsymbol{r}_{2})$
\end_inset

-plane,
 lies in 
\begin_inset Formula $\Omega$
\end_inset

 and is linearly independent of the translational and rotational modes.
\end_layout

\begin_layout Standard
The gauge-fixing conditions (G1)–(G2) remove the 
\begin_inset Formula $\boldsymbol{r}_{1}$
\end_inset

-translation and the rotational mode,
 leaving a 
\begin_inset Formula $2$
\end_inset

-dimensional residual kernel (the 
\begin_inset Formula $\boldsymbol{r}_{2}$
\end_inset

-translation and the breathing mode) that must be handled by the parallel projection 
\begin_inset Formula $P_{w}F$
\end_inset

.
 
