@article{GrillakisShatahStrauss1987,
abstract = {Consider an abstract Hamiltonian system which is invariant under a one-parameter unitary group of operators. By a “solitary wave” we mean a solution the time development of which is given exactly by the one-parameter group. We find sharp conditions for the stability and instability of solitary waves. Applications are given to bound states and traveling waves of nonlinear PDEs such Klein-Gordon and Schr\"odinger equations.},
author = {Grillakis, Manoussos and Shatah, Jalal and Strauss, Walter},
address = {Orlando, FL},
copyright = {1987},
issn = {0022-1236},
journal = {Journal of functional analysis},
keywords = {Physics},
language = {eng},
number = {1},
pages = {160-197},
publisher = {Elsevier Inc},
title = {Stability theory of solitary waves in the presence of symmetry, I},
volume = {74},
year = {1987},
}
