@article{HasegawaTappert1973a,
abstract = {Theoretical calculations supported by numerical simulations show that utilization of the nonlinear dependence of the index of refraction on intensity makes possible the transmission of picosecond optical pulses without distortion in dielectric fiber waveguides with group velocity dispersion. In the case of anomalous dispersion (∂2ω/∂k2>0) discussed here [the case of normal dispersion (∂2ω/∂k2<0) will be discussed in a succeeding letter], the stationary pulse is a ``bright'' pulse, or envelope soliton. For a typical glass fiber guide, the balancing power required to produce a stationary 1-ps pulse is approximately 1 W. Numerical simulations show that above a certain threshold power level such pulses are stable under the influence of small perturbations, large perturbations, white noise, or absorption.},
author = {Hasegawa, Akira and Tappert, Frederick},
issn = {0003-6951},
journal = {Applied physics letters},
language = {eng ; jpn},
number = {3},
pages = {142-144},
title = {Transmission of stationary nonlinear optical pulses in dispersive dielectric fibers. I. Anomalous dispersion},
volume = {23},
year = {1973},
}
@article{Lions1984a,
abstract = {We present here a new method for solving minimization problems in unbounded domains. We first derive a general principle showing the equivalence between the compactness of all minimizing sequences and some strict sub-additivity conditions. The proof is based upon a compactness lemma obtained with the help of the notion of concentration function of a measure. We give various applications to problems arising in Mathematical Physics.},
author = {Lions, P.L.},
copyright = {Copyright 2018 Elsevier B.V., All rights reserved.},
issn = {0294-1449},
journal = {Annales de l'Institut Henri Poincar\'e. Analyse non lin\'eaire},
language = {eng ; jpn},
number = {2},
pages = {109-145},
title = {The concentration-compactness principle in the Calculus of Variations. The locally compact case, part 1},
volume = {1},
year = {1984},
}
@article{Lions1984b,
abstract = {In this paper (sequel of Part 1) we investigate further applications of the concentration-compactness principle to the solution of various minimization problems in unbounded domains. In particular we present here the solution of minimization problems associated with nonlinear field equations.
Dans cette deuxième partie, nous examinons de nouvelles applications du principe de concentration-compacit\'e \'a la r\'esolution dedivers problèmes de minimization dans des ouverts non born\'es. En particulier nous r\'esolvons des problèmes de minimisation associ\'es aux \'equations de champ non lin\'eaires.},
author = {Lions, P.L.},
copyright = {1984 1984 L'Association Publications de l'Institut Henri Poincar\'e. Published by Elsevier B.V.},
issn = {0294-1449},
journal = {Annales de l'Institut Henri Poincar\'e. Analyse non lin\'eaire},
language = {eng},
number = {4},
pages = {223-283},
publisher = {Elsevier Masson SAS},
title = {The concentration-compactness principle in the Calculus of Variations. The Locally compact case, part 2},
volume = {1},
