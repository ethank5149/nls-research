\end_layout

\end_inset

Let 
\begin_inset Formula $R(\theta)$
\end_inset

 be the 
\begin_inset Formula $2\times 2$
\end_inset

 rotation matrix by angle 
\begin_inset Formula $\theta$
\end_inset

 and set 
\begin_inset Formula $y_i=R(\theta)y_i'$
\end_inset

 where 
\begin_inset Formula $y_i'$
\end_inset

 are the canonical equilateral positions. The conjugated Hessian 
\begin_inset Formula $\tilde{H}=R(-\theta)\HV R(\theta)$
\end_inset

 has entries 
\begin_inset Formula \[
\tilde{H} = \begin{pmatrix} \lambda_1\cos^2\theta+\lambda_2\sin^2\theta & (\lambda_2-\lambda_1)\sin\theta\cos\theta \\ (\lambda_2-\lambda_1)\sin\theta\cos\theta & \lambda_2\cos^2\theta+\lambda_1\sin^2\theta \end{pmatrix}.
\]
\end_inset

Solving 
\begin_inset Formula $\tilde{H}\,y_i' = \sum_{k\in N_i}\alpha_{ki}(y_k'-y_i')$
\end_inset

 for each vertex yields the 
\begin_inset Formula $\theta$
\end_inset

-dependent coefficients: 
\begin_inset Formula \begin{align}
\alpha_{12}(\theta) &= \tfrac{1}{3}\bigl[\lambda_2(-\sqrt{3}\sin\theta-\cos\theta)\cos\theta + \lambda_1(-\sin\theta+\sqrt{3}\cos\theta)\sin\theta\bigr], \label{eq:alpha12} \\
\alpha_{13}(\theta) &= \tfrac{1}{3}\bigl[\lambda_2(\sqrt{3}\sin\theta-\cos\theta)\cos\theta - \lambda_1(\sin\theta+\sqrt{3}\cos\theta)\sin\theta\bigr], \label{eq:alpha13} \\
\alpha_{23}(\theta) &= \tfrac{1}{6}\bigl[\lambda_2(2\cos 2\theta-1) - \lambda_1(2\cos 2\theta+1)\bigr]. \label{eq:alpha23}
\end{align}
\end_inset


\end_layout

