\begin_inset Formula \begin{align}
D_{\delta y}P_\perp F(\delta y^0,0)[\delta w] &= P_\perp\sum_{k\in N_i}\ip{\delta w_k-\delta w_i}{y_k-y_i}\,\tilde{\alpha}_{ik}(0)\,\chi\,(y_k-y_i), \label{eq:DPperp} \\
D_{\delta y}P_w F(\delta y^0,0)[\delta w] &= \sum_i\Bigl[\ip{w_i}{\HV\delta w_i} + \sum_{k\in N_i}\tilde{\alpha}_{ki}(0)\bigl(\ip{w_i}{\delta y_k^0-\delta y_i^0}\ip{y_k-y_i}{\delta w_k-\delta w_i} \notag \\
&\quad\qquad - \ip{w_i}{\delta w_k-\delta w_i}\bigr)\Bigr]. \label{eq:DPpar}
\end{align}
\end_inset


