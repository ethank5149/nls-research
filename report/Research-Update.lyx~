\begin_inset Formula $P_w F$
\end_inset

 for 
\begin_inset Formula $w$
\end_inset

 ranging over a basis of 
\begin_inset Formula $\Omega$
\end_inset

.
\end_layout

\begin_layout Standard
At 
\begin_inset Formula $(\delta y^0,0)$
\end_inset

