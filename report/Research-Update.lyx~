\begin_layout Subsection
Formulation
\end_layout

\begin_layout Standard

\begin_inset CommandInset label
LatexCommand label
name "subsec:formulation"

\end_inset


\end_layout

\begin_layout Standard
Write 
\begin_inset Formula $\tilde{y}_i = \tilde{m}_R\,y_i + \delta y_i$
\end_inset

 with 
\begin_inset Formula $\delta y_i/\tilde{m}_R\to 0$
\end_inset

 as 
\begin_inset Formula $R\to 0$
\end_inset

, where 
\begin_inset Formula $\delta y_i\in\operatorname{span}\{\boldsymbol{r}_1,\boldsymbol{r}_2\}$
\end_inset

.
\end_layout

\begin_layout Definition

\begin_inset Argument 1
status collapsed


\begin_layout Standard
Perturbation system
\end_layout

\end_inset


\begin_inset CommandInset label
LatexCommand label
name "def:Fi"

\end_inset

 Define 
\begin_inset Formula \begin{equation}\label{eq:Fi-def}
F_i(\delta y,R) = \HV y_i + \HV\frac{\delta y_i}{\tilde{m}_R} - \sum_{k\in N_i}\frac{2Q_R\bigl(|\tilde{m}_R(y_k-y_i)+\delta y_k-\delta y_i|\bigr)}{\norm{u_R}_{L^2}^2\,R^4\,|\tilde{m}_R(y_k-y_i)+\delta y_k-\delta y_i|}\Bigl(y_k-y_i+\frac{\delta y_k-\delta y_i}{\tilde{m}_R}\Bigr).
\end{equation}
\end_inset

Extending by continuity to 
\begin_inset Formula $R=0$
\end_inset

: 
\begin_inset Formula \begin{equation}\label{eq:Fi-zero}
F_i(\delta y,0) = \HV y_i - \chi\sum_{k\in N_i} e^{-\ip{y_k-y_i}{\delta y_k-\delta y_i}}(y_k-y_i),
\end{equation}
\end_inset

where 
\begin_inset Formula $\chi$
\end_inset

 is the overall interaction strength (Definition
\begin_inset space ~

\end_inset


\begin_inset CommandInset ref
LatexCommand ref
reference "def:chi"
plural "false"
caps "false"
noprefix "false"
nolink "false"

\end_inset

), and the perturbed interaction coefficients are 
\begin_inset Formula $\tilde{\alpha}_{ki}=e^{-\ip{y_k-y_i}{\delta y_k-\delta y_i}}$
\end_inset

, satisfying 
\begin_inset Formula $\tilde{\alpha}_{ki}\chi \to \alpha_{ki}\chi$
\end_inset

 as 
\begin_inset Formula $\delta y\to 0$
\end_inset

. Note that the constraint 
\begin_inset Formula $\max_k\alpha_{ki}=1$
\end_inset

 from
\begin_inset space ~

\end_inset


\begin_inset CommandInset ref
LatexCommand eqref
reference "eq:alpha-def"
plural "false"
caps "false"
noprefix "false"
nolink "false"

\end_inset

 normalizes 
\begin_inset Formula $\chi$
\end_inset

 to equal the total force from a nearest-neighbor pair at minimum distance.
\end_layout

\begin_layout Definition
The Fréchet derivative is 
\begin_inset Formula \begin{equation}\label{eq:Fi-deriv}
D_{\delta y}F_i(\delta y,0)[w] = \chi\sum_{k\in N_i}\ip{w_k-w_i}{y_k-y_i}\,e^{-\ip{y_k-y_i}{\delta y_k-\delta y_i}}(y_k-y_i).
\end{equation}
\end_inset


\end_layout

\begin_layout Subsection
Explicit solution at 
\begin_inset Formula $R=0$
\end_inset


\end_layout

\begin_layout Standard

\begin_inset CommandInset label
LatexCommand label
name "subsec:explicit"

\end_inset


\end_layout

\begin_layout Proposition

\begin_inset Argument 1
status collapsed


\begin_layout Standard
Explicit solution
\end_layout

\end_inset


\begin_inset CommandInset label
LatexCommand label
name "prop:explicit-soln"

\end_inset

 Define 
\begin_inset Formula $\beta=\frac{1}{2}\ln(\alpha_{12}/\alpha_{23})$
\end_inset

 and 
\begin_inset Formula $\gamma=\frac{2\beta}{3\sqrt{3}}$
\end_inset

, where 
\begin_inset Formula $\alpha_{12}=-\lambda_2/3$
\end_inset

 and 
\begin_inset Formula $\alpha_{23}=\lambda_2/6-\lambda_1/2$
\end_inset

 are the unperturbed coefficients. Then 
\begin_inset Formula \begin{equation}\label{eq:delta-y0}
\delta y_1^0 = -\gamma\,\boldsymbol{r}_2, \qquad \delta y_{2,3}^0 = \mp\beta\,\boldsymbol{r}_1 + \tfrac{\gamma}{2}\,\boldsymbol{r}_2
\end{equation}
\end_inset

solves 
\begin_inset Formula $F_i(\delta y,0)=0$
\end_inset

 for 
\begin_inset Formula $i=1,2,3$
\end_inset

. 
\end_layout

\begin_layout Proof
The perturbed interaction coefficients at 
\begin_inset Formula $\delta y^0$
\end_inset

 are (computed by direct substitution): 
\begin_inset Formula \begin{align*}
\tilde{\alpha}_{12} = \tilde{\alpha}_{13} &= e^{-\ip{y_2-y_1}{\delta y_2^0-\delta y_1^0}} = 1, \\
\tilde{\alpha}_{23} = \tilde{\alpha}_{32} &= e^{-\ip{y_3-y_2}{\delta y_3^0-\delta y_2^0}} = \frac{\alpha_{23}}{\alpha_{12}}.
\end{align*}
\end_inset

The first follows from the fact that 
\begin_inset Formula $\ip{y_2-y_1}{\delta y_2^0-\delta y_1^0}=0$
\end_inset

 (which one verifies by substituting the explicit coordinates). The second uses 
\begin_inset Formula $\ip{y_3-y_2}{\delta y_3^0-\delta y_2^0}=2\beta=\ln(\alpha_{12}/\alpha_{23})$
\end_inset

.
\end_layout

\begin_layout Proof
Setting 
\begin_inset Formula $\chi=\alpha_{12}$
\end_inset

 (the nearest-neighbor coefficient), the system 
\begin_inset Formula $F_i(\delta y^0,0)=0$
\end_inset

 becomes 
\begin_inset Formula \[
\HV y_i = \alpha_{12}\bigl[\tilde{\alpha}_{i1}(y_1-y_i) + \tilde{\alpha}_{i,\text{other}}(y_{\text{other}}-y_i)\bigr]
\]
\end_inset

for each 
\begin_inset Formula $i$
\end_inset

, which reduces to the original algebraic system
\begin_inset space ~

\end_inset


\begin_inset CommandInset ref
LatexCommand eqref
reference "eq:algebraic"
plural "false"
caps "false"
noprefix "false"
nolink "false"

\end_inset

. Substituting the known values and simplifying component-wise confirms 
\begin_inset Formula $F_i=0$
\end_inset

 for each 
\begin_inset Formula $i$
\end_inset

.
\end_layout

\begin_layout Proof
We also verify the center-of-mass condition: 
\begin_inset Formula $\delta y_1^0+\delta y_2^0+\delta y_3^0 = (0,0)$
\end_inset

, which is immediate from the definitions. 
\end_layout

\begin_layout Subsection
Kernel of the linearization
\end_layout

\begin_layout Standard

\begin_inset CommandInset label
LatexCommand label
name "subsec:kernel"

\end_inset


\end_layout

\begin_layout Proposition

\begin_inset Argument 1
status collapsed


\begin_layout Standard
Nontrivial kernel
\end_layout

\end_inset


\begin_inset CommandInset label
LatexCommand label
name "prop:kernel"

\end_inset

 The linearization 
\begin_inset Formula $D_{\delta y}F_i(\delta y^0,0)$
\end_inset

 has a four-dimensional kernel 
\begin_inset Formula \[
\Omega = \{(w_1,w_2,w_3)\in(\R^2)^3 : \ip{w_k-w_i}{y_k-y_i}=0\;\;\forall\, i\neq k\}.
\]
\end_inset

This kernel contains the two-dimensional translational subspace 
\begin_inset Formula $\{(v,v,v):v\in\R^2\}$
\end_inset

 and two additional directions, including the rotational mode 
\begin_inset Formula $w_{\mathrm{rot}}=\frac{d}{d\theta}y_i(\theta)\big|_{\theta=0}$
\end_inset

. 
\end_layout

\begin_layout Proof
The kernel condition 
\begin_inset Formula $\ip{w_k-w_i}{y_k-y_i}=0$
\end_inset

 for all neighbor pairs gives three scalar constraints on 
\begin_inset Formula $w\in\R^6$
\end_inset

. Since 
\begin_inset Formula $y_3-y_2 = (y_3-y_1)-(y_2-y_1)$
\end_inset

, only two constraints are independent, so 
\begin_inset Formula $\dim\Omega\geq 6-2=4$
\end_inset

.
\end_layout

\begin_layout Proof
To see that 
\begin_inset Formula $\Omega\supseteq\{(v,v,v):v\in\R^2\}$
\end_inset

: if 
\begin_inset Formula $w_1=w_2=w_3=v$
\end_inset

, then 
\begin_inset Formula $w_k-w_i=0$
\end_inset

, so all inner products vanish. This is a 2D subspace.
\end_layout

\begin_layout Proof
The quadratic form argument shows the inclusion is an equality: define 
\begin_inset Formula \[
\Phi = \sum_i w_i\cdot D_{\delta y}F_i(\delta y^0,0)[w] = -\chi\sum_{\{i,k\}\in\text{edges}}\alpha_{ik}\bigl(\ip{w_k-w_i}{y_k-y_i}\bigr)^2.
\]
\end_inset

Since 
\begin_inset Formula $\Phi\leq 0$
\end_inset

 and 
\begin_inset Formula $\Phi=0$
\end_inset

 implies each summand vanishes (as 
\begin_inset Formula $\alpha_{ik}>0$
\end_inset

 for all edges of the equilateral triangle), the kernel is precisely 
\begin_inset Formula $\Omega$
\end_inset

. Computing explicitly, 
\begin_inset Formula $\dim\Omega=4$
\end_inset

.
\end_layout

\begin_layout Proof
The rotational mode 
\begin_inset Formula $w_{\mathrm{rot}}=(\frac{d}{d\theta}y_i(\theta)|_{\theta=0})_{i=1,2,3}=(-h,0;\;\frac{h}{2},-a;\;\frac{h}{2},a)$
\end_inset

 lies in 
\begin_inset Formula $\Omega$
\end_inset

 since 
\begin_inset Formula $\ip{w_{\mathrm{rot},k}-w_{\mathrm{rot},i}}{y_k-y_i}=0$
\end_inset

 for all pairs (verified by direct computation). 
\end_layout

