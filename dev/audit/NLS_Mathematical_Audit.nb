9. Rescaling Verification (Section 2 of Paper)
Verify that the rescaling u_E(x) = E^{-1/(2p)} \[Psi]_E(E^{-1/2} x) transforms the NLS correctly.
Cell[BoxData[{RowBox[{RowBox[{"(*"," ",RowBox[{"Symbolic"," ","verification"," ","of"," ","the"," ","rescaling"}]," ","*)"}]}],"\n",RowBox[{RowBox[{"(*"," ",RowBox[{RowBox[{"Starting"," ","from"," ",RowBox[{"(",RowBox[{RowBox[{"-","\[CapitalDelta]"}]," ","+"," ","V"," ","+"," ","E"}],")"}],"\[Psi]"}]," ","+"," ",RowBox[{"\[Sigma]"," ",SuperscriptBox[RowBox[{"|","\[Psi]","|"}],RowBox[{"2","p"}]],"\[Psi]"}]," ","="," ","0"}]," ","*)"}]}],"\n",RowBox[{RowBox[{"(*"," ",RowBox[{RowBox[{RowBox[{"Define"," ","u_E",RowBox[{"(","x",")"}]}]," ","="," ",RowBox[{SuperscriptBox["E",RowBox[{RowBox[{"-","1"}],"/",RowBox[{"(",RowBox[{"2","p"}],")"}]}]]," ","\[Psi]_E",RowBox[{"(",RowBox[{SuperscriptBox["E",RowBox[{RowBox[{"-","1"}],"/","2"}]],"x"}],")"}]}]}],","," ",RowBox[{"then"," ",RowBox[{"(",RowBox[{RowBox[{"-","\[CapitalDelta]"}],"+",RowBox[{SuperscriptBox["R","2"],"V",RowBox[{"(","Rx",")"}]}],"+","1"}],")"}],"u_E"," ","+"," ",RowBox[{"\[Sigma]",SuperscriptBox[RowBox[{"|","u_E","|"}],RowBox[{"2","p"}]],"u_E"}]," ","="," ","0"}]}]," ","*)"}]}],"\n",RowBox[{RowBox[{"Print","[","\"\<\\n=== Rescaling Verification ===\"","]"}],";"}],"\n",RowBox[{RowBox[{"Print","[","\"\<Let R = E^{-1/2}. The substitution u_E(x) = E^{-1/(2p)} \[Psi]_E(Rx) gives:\>\"","]"}],";"}],"\n",RowBox[{RowBox[{"Print","[","\"\<  \[CapitalDelta]_x \[Psi](Rx) = R^2 (\[CapitalDelta]_y \[Psi])(Rx) where y = Rx\>\"","]"}],";"}],"\n",RowBox[{RowBox[{"Print","[","\"\<  E^{-1/(2p)} * R^2 * E = E^{-1/(2p)} * E^{-1} * E = E^{-1/(2p)}  \[Checkmark]\>\"","]"}],";"}],"\n",RowBox[{RowBox[{"Print","[","\"\<  Nonlinear: E^{-1/(2p)} * |E^{-1/(2p)}\[Psi]|^{2p} * E^{-1/(2p)}\[Psi] = E^{-(2p+1)/(2p)} |\[Psi]|^{2p}\[Psi]\>\"","]"}],";"}],"\n",RowBox[{RowBox[{"Print","[","\"\<  Factor: E^{-1/(2p)} * E^1 = E^{(2p-1)/(2p)} for the linear term\>\"","]"}],";"}],"\n",RowBox[{RowBox[{"Print","[","\"\<  After dividing by E^{(2p-1)/(2p)}: (-\[CapitalDelta] + R^2 V(Rx) + 1)u + \[Sigma]|u|^{2p}u = 0  \[Checkmark]\>\"","]"}],";"}]}],"Input",C