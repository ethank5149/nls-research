2. Isosceles Triangle (Example 3.2 of Paper)
Verify that the isosceles triangle algebraic system yields \[Alpha]12 = \[Alpha]13 = -\[Lambda]2/3 and \[Lambda]2 = 3\[Lambda]1.
(* Isosceles triangle: 2a > 1 *)
Module[{aI,hI,y1I,y2I,y3I,\[Alpha]12I,\[Alpha]13I,eq1,eq2,eq3},
{y1I,y2I,y3I}={{0,hI},{-aI,-hI/2},{aI,-hI/2}};
(* From H_V y1 = \[Alpha]12(y2-y1) + \[Alpha]13(y3-y1) *)
eq1=Hv.y1I-(\[Alpha]12I (y2I-y1I)+\[Alpha]13I (y3I-y1I));
(* Solve the system *)
Print["\nIsosceles: Equation from y1 gives:\n",
Solve[eq1[[1]]==0&&eq1[[2]]==0,{\[Alpha]12I,\[Alpha]13I}]];
Print["Expected: \[Alpha]12 = \[Alpha]13 = -\[Lambda]2/3"]
];

(* Now verify from the y2 equation *)
Module[{aI,hI,y1I,y2I,y3I,\[Alpha]12I,eq2},
{y1I,y2I,y3I}={{0,hI},{-aI,-hI/2},{aI,-hI/2}};
(* H_V y2 = \[Alpha]12(y1-y2) (* y3 not nearest neighbor *) *)
eq2=Hv.y2I-\[Alpha]12I (y1I-y2I);
Print["\nIsosceles: Equation from y2:\n  Component 1: ",Simplify[eq2[[1]]]," = 0"];
Print["  Component 2: ",Simplify[eq2[[2]]]," = 0"];
Print["From comp 1: \[Alpha]12 = -\[Lambda]1. From comp 2: \[Alpha]12 = -\[Lambda]2/3. Hence \[Lambda]2 = 3\[Lambda]1."]
];\.00
\.00
3. Equilateral Triangle (Example 3.3 of Paper)
Verify \[Alpha]12 = -\[Lambda]2/3, \[Alpha]23 = \[Lambda]2/6 - \[Lambda]1/2, and the binding constraint |\[Lambda]2|/|\[Lambda]1| >= 3.
(* Full equilateral triangle algebraic system *)
Module[{\[Alpha]12eq,\[Alpha]13eq,\[Alpha]23eq,eq1,eq2,eq3,sol},
(* Three equations from the algebraic system *)
eq1=Hv.y1-(\[Alpha]12eq(y2-y1)+\[Alpha]13eq(y3-y1));
eq2=Hv.y2-(\[Alpha]12eq(y1-y2)+\[Alpha]23eq(y3-y2));
eq3=Hv.y3-(\[Alpha]13eq(y1-y3)+\[Alpha]23eq(y2-y3));
sol=Solve[Thread[eq1==0]&&Thread[eq2==0]&&Thread[eq3==0],{\[Alpha]12eq,\[Alpha]13eq,\[Alpha]23eq}];
Print["\nEquilateral triangle solution:\n",sol];
Print["\nExpected: \[Alpha]12 = \[Alpha]13 = -\[Lambda]2/3, \[Alpha]23 = \[Lambda]2/6 - \[Lambda]1/2"];
(* Verify binding constraint *)
Print["\nBinding constraint \[Alpha]23 >= 0:\n  \[Lambda]2/6 - \[Lambda]1/2 >= 0  \[DoubleLongLeftRightArrow]  \[Lambda]2 >= 3\[Lambda]1  \[DoubleLongLeftRightArrow]  |\[Lambda]2|/|\[Lambda]1| >= 3 (since both negative)"]
];
4. Rotational Equilateral Triangle (Example 3.4)
Verify the \[Theta]-dependent interaction coefficients \[Alpha]12(\[Theta]), \[Alpha]13(\[Theta]), \[Alpha]23(\[Theta]).
Cell[BoxData[{RowBox[{RowBox[{"(*"," ",RowBox[{"Rotation"," ","matrix"}]," ","*)"}]}],"\n",RowBox[{RowBox[{RowBox[{"R\[Theta]","[","\[Theta]_","]"}],":=",RowBox[{"{",RowBox[{RowBox[{"{",RowBox[{RowBox[{"Cos","[","\[Theta]","]"}],",",RowBox[{"-",RowBox[{"Sin","[","\[Theta]","]"}]}]}],"}"}],",",RowBox[{"{",RowBox[{RowBox[{"Sin","[","\[Theta]","]"}],",",RowBox[{"Cos","[","\[Theta]","]"}]}],"}"}]}],"}"}]}],";"}],"\n",RowBox[{RowBox[{RowBox[{"Rinv\[Theta]","[","\[Theta]_","]"}],":=",RowBox[{"Transpose","[",RowBox[{"R\[Theta]","[","\[Theta]","]"}],"]"}]}],";"}],"\n",RowBox[{RowBox[{"(*"," ",RowBox[{"Rotated"," ","peak"," ","positions"}]," ","*)"}]}],"\n",RowBox[{RowBox[{RowBox[{"y1r","[","\[Theta]_","]"}],":=",RowBox[{RowBox[{"R\[Theta]","[","\[Theta]","]"}],".","y1"}]}],";"}],"\n",RowBox[{RowBox[{RowBox[{"y2r","[","\[Theta]_","]"}],":=",RowBox[{RowBox[{"R\[Theta]","[","\[Theta]","]"}],".","y2"}]}],";"}],"\n",RowBox[{RowBox[{RowBox[{"y3r","[","\[Theta]_","]"}],":=",RowBox[{RowBox[{"R\[Theta]","[","\[Theta]","]"}],".","y3"}]}],";"}],"\n",RowBox[{RowBox[{"(*"," ",RowBox[{"Conjugated"," ","Hessian",":"," ",RowBox[{RowBox[{"R","^",RowBox[{"{",RowBox[{"-","1"}],"}"}]}]," ","H_V"," ","R"}]}]," ","*)"}]}],"\n",RowBox[{RowBox[{RowBox[{"HvRot","[","\[Theta]_","]"}],":=",RowBox[{"Simplify","[",RowBox[{RowBox[{"Rinv\[Theta]","[","\[Theta]","]"}],".","Hv",".",RowBox[{"R\[Theta]","[","\[Theta]","]"}]}],"]"}]}],";"}]}],"Input",CellLabel->"In[21]:="],
(* Rotation matrix *)
R\[Theta][\[Theta]_]:={{Cos[\[Theta]],-Sin[\[Theta]]},{Sin[\[Theta]],Cos[\[Theta]]}};
Rinv\[Theta][\[Theta]_]:=Transpose[R\[Theta][\[Theta]]];
(* Rotated peak positions *)
y1r[\[Theta]_]:=R\[Theta][\[Theta]].y1;
y2r[\[Theta]_]:=R\[Theta][\[Theta]].y2;
y3r[\[Theta]_]:=R\[Theta][\[Theta]].y3;
(* Conjugated Hessian: R^{-1} H_V R *)
HvRot[\[Theta]_]:=Simplify[Rinv\[Theta][\[Theta]].Hv.R\[Theta][\[Theta]]];\.00
(* Derive \[Alpha]12, \[Alpha]13, \[Alpha]23 from the three equilibrium equations *)
Module[{\[Alpha]12r,\[Alpha]13r,\[Alpha]23r,eq1r,eq2r,eq3r,solr},
(* Equation from y1: R^{-1} H_V R y1' = \[Alpha]12(y2'-y1') + \[Alpha]13(y3'-y1') *)
eq1r=Simplify[HvRot[\[Theta]].y1-(\[Alpha]12r(y2-y1)+\[Alpha]13r(y3-y1))];
eq2r=Simplify[HvRot[\[Theta]].y2-(\[Alpha]12r(y1-y2)+\[Alpha]23r(y3-y2))];
eq3r=Simplify[HvRot[\[Theta]].y3-(\[Alpha]13r(y1-y3)+\[Alpha]23r(y2-y3))];
solr=Simplify[Solve[Thread[eq1r==0]&&Thread[eq2r==0]&&Thread[eq3r==0],{\[Alpha]12r,\[Alpha]13r,\[Alpha]23r}]];
Print["\nRotational equilateral: general solution for \[Alpha]'s:\n",solr//TableForm]
];\.00
5. Admissibility Constraints (\[Alpha] >= 0 Analysis)
Verify the double-angle reduction and the \[Nu](\[Mu]), \[CurlyPhi](\[Mu]) functions.
(* Paper's claimed expressions *)
\[Alpha]12paper[\[Theta]_]:=1/3(\[Lambda]2(-Sqrt[3]Sin[\[Theta]]-Cos[\[Theta]])Cos[\[Theta]]+\[Lambda]1(-Sin[\[Theta]]+Sqrt[3]Cos[\[Theta]])Sin[\[Theta]]);
\[Alpha]13paper[\[Theta]_]:=1/3(\[Lambda]2(Sqrt[3]Sin[\[Theta]]-Cos[\[Theta]])Cos[\[Theta]]-\[Lambda]1(Sin[\[Theta]]+Sqrt[3]Cos[\[Theta]])Sin[\[Theta]]);
\[Alpha]23paper[\[Theta]_]:=1/6(\[Lambda]2(2Cos[2\[Theta]]-1)-\[Lambda]1(2Cos[2\[Theta]]+1));
(* Check at \[Theta]=0 recovers the canonical equilateral case *)
Print["\n\[Theta]=0 check:\n  \[Alpha]12(0) = ",Simplify[\[Alpha]12paper[0]],"  (expected -\[Lambda]2/3)"];
Print["  \[Alpha]13(0) = ",Simplify[\[Alpha]13paper[0]],"  (expected -\[Lambda]2/3)"];
Print["  \[Alpha]23(0) = ",Simplify[\[Alpha]23paper[0]],"  (expected \[Lambda]2/6 - \[Lambda]1/2)"];
(* The three admissibility inequalities in terms of \[Mu] *)
(* Substitute \[Lambda]1 = -1 and \[Lambda]2 = -\[Mu] (WLOG, since we only care about the ratio) *)
\[Alpha]12\[Mu][\[Theta]_]:=\[Alpha]12paper[\[Theta]]/.{\[Lambda]1->-1,\[Lambda]2->-\[Mu]};
\[Alpha]13\[Mu][\[Theta]_]:=\[Alpha]13paper[\[Theta]]/.{\[Lambda]1->-1,\[Lambda]2->-\[Mu]};
\[Alpha]23\[Mu][\[Theta]_]:=\[Alpha]23paper[\[Theta]]/.{\[Lambda]1->-1,\[Lambda]2->-\[Mu]};
(* Verify double-angle reduction *)
(* Paper claims \[Alpha]12 >= 0 \[DoubleLongLeftRightArrow] (\[Mu]+1)+2(\[Mu]-1)Cos[2\[Theta]-\[Pi]/3]>=0 *)
ineq1doubleAngle[\[Theta]_]:=(\[Mu]+1)+2(\[Mu]-1)Cos[2\[Theta]-\[Pi]/3];
ineq2doubleAngle[\[Theta]_]:=(\[Mu]+1)+2(\[Mu]-1)Cos[2\[Theta]+\[Pi]/3];
ineq3doubleAngle[\[Theta]_]:=(\[Mu]+1)-2(\[Mu]-1)Cos[2\[Theta]];
(* Check equivalence symbolically *)
Print["\nDouble-angle reduction check (should all be 0):"];
Print["  6*\[Alpha]12 - ineq1: ",FullSimplify[6\[Alpha]12\[Mu][\[Theta]]-ineq1doubleAngle[\[Theta]]]];
Print["  6*\[Alpha]13 - ineq2: ",FullSimplify[6\[Alpha]13\[Mu][\[Theta]]-ineq2doubleAngle[\[Theta]]]];
Print["  6*\[Alpha]23 - ineq3: ",FullSimplify[6\[Alpha]23\[Mu][\[Theta]]-ineq3doubleAngle[\[Theta]]]];
\.00
