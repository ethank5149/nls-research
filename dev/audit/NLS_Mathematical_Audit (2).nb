Notebook[{

Cell[TextData[{
 "Mathematical Audit Notebook\n",
 StyleBox["Multi-Peak Ground States of the NLS\nKirr & Knox (2026)", FontSize->16, FontColor->GrayLevel[0.4]]
}], "Title"],

Cell["This notebook verifies every mathematical claim in the research report. Evaluate all cells in order. Interactive demonstrations in Section 8 require a Mathematica front end or Wolfram Cloud.", "Text"],

Cell[CellGroupData[{
Cell["1. Core Definitions and Geometry", "Section"],
Cell["Define equilateral triangle geometry, peak positions, and Hessian.", "Text"],
Cell[BoxData[{
 RowBox[{RowBox[{"ClearAll", "[", "\"Global`*\"", "]"}], ";"}], "\n",
 RowBox[{RowBox[{RowBox[{"{", RowBox[{"a", ",", "h"}], "}"}], "=", RowBox[{"{", RowBox[{FractionBox["1", "2"], ",", FractionBox["1", SqrtBox["3"]]}, "}"}]}], ";"}], "\n",
 RowBox[{RowBox[{RowBox[{"{", RowBox[{"y1", ",", "y2", ",", "y3"}], "}"}], "=", RowBox[{"{", RowBox[{RowBox[{"{", RowBox[{"0", ",", "h"}], "}"}], ",", RowBox[{"{", RowBox[{RowBox[{"-", "a"}], ",", RowBox[{"-", FractionBox["h", "2"]}]}], "}"}], ",", RowBox[{"{", RowBox[{"a", ",", RowBox[{"-", FractionBox["h", "2"]}]}], "}"}]}], "}"}]}], ";"}], "\n",
 RowBox[{RowBox[{"Hv", "=", RowBox[{"DiagonalMatrix", "[", RowBox[{"{", RowBox[{"\[Lambda]1", ",", "\[Lambda]2"}], "}"}], "]"}]}], ";"}], "\n",
 RowBox[{RowBox[{RowBox[{"R\[Theta]", "[", "\[Theta]_", "]"}], ":=", RowBox[{"{", RowBox[{RowBox[{"{", RowBox[{RowBox[{"Cos", "[", "\[Theta]", "]"}], ",", RowBox[{"-", RowBox[{"Sin", "[", "\[Theta]", "]"}]}]}], "}"}], ",", RowBox[{"{", RowBox[{RowBox[{"Sin", "[", "\[Theta]", "]"}], ",", RowBox[{"Cos", "[", "\[Theta]", "]"}]}], "}"}]}], "}"}]}], ";"}], "\n",
 RowBox[{RowBox[{RowBox[{"HvRot", "[", "\[Theta]_", "]"}], ":=", RowBox[{"Simplify", "[", RowBox[{RowBox[{"Transpose", "[", RowBox[{"R\[Theta]", "[", "\[Theta]", "]"}], "]"}], ".", "Hv", ".", RowBox[{"R\[Theta]", "[", "\[Theta]", "]"}]}], "]"}]}], ";"}], "\n",
 RowBox[{"Grid", "[", RowBox[{RowBox[{"{", RowBox[{RowBox[{"{", RowBox[{RowBox[{"Style", "[", RowBox[{"\"Check\"", ",", "Bold"}], "]"}], ",", RowBox[{"Style", "[", RowBox[{"\"Value\"", ",", "Bold"}], "]"}], ",", RowBox[{"Style", "[", RowBox[{"\"Expected\"", ",", "Bold"}], "]"}]}], "}"}], ",", RowBox[{"{", RowBox[{"\"2a\"", ",", RowBox[{"2", "a"}], ",", "1"}], "}"}], ",", RowBox[{"{", RowBox[{"\"a\[TwoSuperior]+9h\[TwoSuperior]/4\"", ",", RowBox[{"Simplify", "[", RowBox[{RowBox[{"a", "^", "2"}], "+", RowBox[{RowBox[{"(", RowBox[{RowBox[{"3", "h"}], "/", "2"}], ")"}], "^", "2"}]}], "]"}], ",", "1"}], "}"}], ",", RowBox[{"{", RowBox[{"\"|y1-y2|\"", ",", RowBox[{"Simplify", "[", RowBox[{"Norm", "[", RowBox[{"y1", "-", "y2"}], "]"}], "]"}], ",", "1"}], "}"}], ",", RowBox[{"{", RowBox[{"\"|y1-y3|\"", ",", RowBox[{"Simplify", "[", RowBox[{"Norm", "[", RowBox[{"y1", "-", "y3"}], "]"}], "]"}], ",", "1"}], "}"}], ",", RowBox[{"{", RowBox[{"\"|y2-y3|\"", ",", RowBox[{"Simplify", "[", RowBox[{"Norm", "[", RowBox[{"y2", "-", "y3"}], "]"}], "]"}], ",", "1"}], "}"}]}], "}"}], ",", RowBox[{"Frame", "->", "All"}], ",", RowBox[{"Spacings", "->", RowBox[{"{", RowBox[{"2", ",", "1"}], "}"}]}]}], "]"}]
}], "Input", CellLabel->"In[1]:="]
}, Open]],

Cell[CellGroupData[{
Cell["2. Equilateral Triangle \[LongDash] Theorem 3.1(c)", "Section"],
Cell["Solve the full 3-vertex algebraic system.", "Text"],
Cell[BoxData[{
 RowBox[{RowBox[{"Module", "[", RowBox[{RowBox[{"{", RowBox[{"\[Alpha]12eq", ",", "\[Alpha]13eq", ",", "\[Alpha]23eq", ",", "eq1", ",", "eq2", ",", "eq3", ",", "sol"}], "}"}], ",", RowBox[{RowBox[{"eq1", "=", RowBox[{RowBox[{"Hv", ".", "y1"}], "-", RowBox[{"(", RowBox[{RowBox[{"\[Alpha]12eq", " ", RowBox[{"(", RowBox[{"y2", "-", "y1"}], ")"}]}], "+", RowBox[{"\[Alpha]13eq", " ", RowBox[{"(", RowBox[{"y3", "-", "y1"}], ")"}]}]}], ")"}]}]}], ";", RowBox[{"eq2", "=", RowBox[{RowBox[{"Hv", ".", "y2"}], "-", RowBox[{"(", RowBox[{RowBox[{"\[Alpha]12eq", " ", RowBox[{"(", RowBox[{"y1", "-", "y2"}], ")"}]}], "+", RowBox[{"\[Alpha]23eq", " ", RowBox[{"(", RowBox[{"y3", "-", "y2"}], ")"}]}]}], ")"}]}]}], ";", RowBox[{"eq3", "=", RowBox[{RowBox[{"Hv", ".", "y3"}], "-", RowBox[{"(", RowBox[{RowBox[{"\[Alpha]13eq", " ", RowBox[{"(", RowBox[{"y1", "-", "y3"}], ")"}]}], "+", RowBox[{"\[Alpha]23eq", " ", RowBox[{"(", RowBox[{"y2", "-", "y3"}], ")"}]}]}], ")"}]}]}], ";", RowBox[{"sol", "=", RowBox[{"Solve", "[", RowBox[{RowBox[{RowBox[{"Thread", "[", RowBox[{"eq1", "==", "0"}], "]"}], "&&", RowBox[{"Thread", "[", RowBox[{"eq2", "==", "0"}], "]"}], "&&", RowBox[{"Thread", "[", RowBox[{"eq3", "==", "0"}], "]"}]}], ",", RowBox[{"{", RowBox[{"\[Alpha]12eq", ",", "\[Alpha]13eq", ",", "\[Alpha]23eq"}], "}"}]}], "]"}]}], ";", RowBox[{"Column", "[", RowBox[{"{", RowBox[{RowBox[{"Style", "[", RowBox[{"\"Interaction coefficients:\"", ",", "Bold", ",", "14"}], "]"}], ",", RowBox[{"sol", "//", "TableForm"}], ",", RowBox[{"Style", "[", RowBox[{"\"Binding: \[Alpha]23\[GreaterEqual]0 \[DoubleLeftRightArrow] |\[Lambda]2/\[Lambda]1|\[GreaterEqual]3\"", ",", RowBox[{"Darker", "[", "Blue", "]"}]}], "]"}]}], "}"}], "]"}]}]}], "]"}], ";"}]
}], "Input", CellLabel->"In[8]:="]
}, Open]],

Cell[CellGroupData[{
Cell["3. Rotational \[Alpha] Coefficients \[LongDash] Theorem 3.1(d)", "Section"],
Cell[BoxData[{
 RowBox[{RowBox[{"\[Alpha]12paper", "[", "\[Theta]_", "]"}], ":=", RowBox[{FractionBox["1", "3"], RowBox[{"(", RowBox[{RowBox[{"\[Lambda]2", RowBox[{"(", RowBox[{RowBox[{RowBox[{"-", SqrtBox["3"]}], RowBox[{"Sin", "[", "\[Theta]", "]"}]}], "-", RowBox[{"Cos", "[", "\[Theta]", "]"}]}], ")"}], RowBox[{"Cos", "[", "\[Theta]", "]"}]}], "+", RowBox[{"\[Lambda]1", RowBox[{"(", RowBox[{RowBox[{"-", RowBox[{"Sin", "[", "\[Theta]", "]"}]}], "+", RowBox[{SqrtBox["3"], RowBox[{"Cos", "[", "\[Theta]", "]"}]}]}], ")"}], RowBox[{"Sin", "[", "\[Theta]", "]"}]}]}], ")"}]}]}], "\n",
 RowBox[{RowBox[{"\[Alpha]13paper", "[", "\[Theta]_", "]"}], ":=", RowBox[{FractionBox["1", "3"], RowBox[{"(", RowBox[{RowBox[{"\[Lambda]2", RowBox[{"(", RowBox[{RowBox[{SqrtBox["3"], RowBox[{"Sin", "[", "\[Theta]", "]"}]}], "-", RowBox[{"Cos", "[", "\[Theta]", "]"}]}], ")"}], RowBox[{"Cos", "[", "\[Theta]", "]"}]}], "-", RowBox[{"\[Lambda]1", RowBox[{"(", RowBox[{RowBox[{"Sin", "[", "\[Theta]", "]"}], "+", RowBox[{SqrtBox["3"], RowBox[{"Cos", "[", "\[Theta]", "]"}]}]}], ")"}], RowBox[{"Sin", "[", "\[Theta]", "]"}]}]}], ")"}]}]}], "\n",
 RowBox[{RowBox[{"\[Alpha]23paper", "[", "\[Theta]_", "]"}], ":=", RowBox[{FractionBox["1", "6"], RowBox[{"(", RowBox[{RowBox[{"\[Lambda]2", RowBox[{"(", RowBox[{RowBox[{"2", RowBox[{"Cos", "[", RowBox[{"2", "\[Theta]"}], "]"}]}], "-", "1"}], ")"}]}], "-", RowBox[{"\[Lambda]1", RowBox[{"(", RowBox[{RowBox[{"2", RowBox[{"Cos", "[", RowBox[{"2", "\[Theta]"}], "]"}]}], "+", "1"}], ")"}]}]}], ")"}]}]}], "\n",
 RowBox[{"Grid", "[", RowBox[{RowBox[{"{", RowBox[{RowBox[{"{", RowBox[{RowBox[{"Style", "[", RowBox[{"\"Coeff\"", ",", "Bold"}], "]"}], ",", RowBox[{"Style", "[", RowBox[{"\"\[Alpha](0)\"", ",", "Bold"}], "]"}], ",", RowBox[{"Style", "[", RowBox[{"\"Expected\"", ",", "Bold"}], "]"}]}], "}"}], ",", RowBox[{"{", RowBox[{"\"\[Alpha]12\"", ",", RowBox[{"Simplify", "[", RowBox[{"\[Alpha]12paper", "[", "0", "]"}], "]"}], ",", RowBox[{"-", FractionBox["\[Lambda]2", "3"]}]}], "}"}], ",", RowBox[{"{", RowBox[{"\"\[Alpha]13\"", ",", RowBox[{"Simplify", "[", RowBox[{"\[Alpha]13paper", "[", "0", "]"}], "]"}], ",", RowBox[{"-", FractionBox["\[Lambda]2", "3"]}]}], "}"}], ",", RowBox[{"{", RowBox[{"\"\[Alpha]23\"", ",", RowBox[{"Simplify", "[", RowBox[{"\[Alpha]23paper", "[", "0", "]"}], "]"}], ",", RowBox[{FractionBox["\[Lambda]2", "6"], "-", FractionBox["\[Lambda]1", "2"]}]}], "}"}]}], "}"}], ",", RowBox[{"Frame", "->", "All"}]}], "]"}]
}], "Input", CellLabel->"In[10]:="]
}, Open]],

Cell[CellGroupData[{
Cell["4. Admissibility \[LongDash] Proposition 3.5", "Section"],
Cell["Verify double-angle reduction and \[Nu](\[Mu]) boundary values.", "Text"],
Cell[BoxData[{
 RowBox[{"Column", "[", RowBox[{"{", RowBox[{RowBox[{"Style", "[", RowBox[{"\"Double-angle equivalence (should be 0):\"", ",", "Bold"}], "]"}], ",", RowBox[{"Row", "[", RowBox[{"{", RowBox[{"\"6\[Alpha]12 \[Minus] ineq1 = \"", ",", RowBox[{"FullSimplify", "[", RowBox[{RowBox[{"6", RowBox[{"(", RowBox[{RowBox[{"\[Alpha]12paper", "[", "\[Theta]", "]"}], "/.", RowBox[{"{", RowBox[{RowBox[{"\[Lambda]1", "->", RowBox[{"-", "1"}]}], ",", RowBox[{"\[Lambda]2", "->", RowBox[{"-", "\[Mu]"}]}]}], "}"}]}], ")"}]}], "-", RowBox[{"(", RowBox[{RowBox[{"(", RowBox[{"\[Mu]", "+", "1"}], ")"}], "+", RowBox[{"2", RowBox[{"(", RowBox[{"\[Mu]", "-", "1"}], ")"}], RowBox[{"Cos", "[", RowBox[{RowBox[{"2", "\[Theta]"}], "-", FractionBox["\[Pi]", "3"]}], "]"}]}]}], ")"}]}], "]"}]}], "}"}], "]"}], ",", RowBox[{"Style", "[", RowBox[{"\"\n\[Nu] boundary values:\"", ",", "Bold"}], "]"}], ",", RowBox[{"Grid", "[", RowBox[{RowBox[{"{", RowBox[{RowBox[{"{", RowBox[{RowBox[{"Style", "[", RowBox[{"\"\[Mu]\"", ",", "Bold"}], "]"}], ",", RowBox[{"Style", "[", RowBox[{"\"\[Nu](\[Mu])\"", ",", "Bold"}], "]"}], ",", RowBox[{"Style", "[", RowBox[{"\"Meaning\"", ",", "Bold"}], "]"}]}], "}"}], ",", RowBox[{"{", RowBox[{"\"1/3\"", ",", FractionBox[RowBox[{FractionBox["1", "3"], "+", "1"}], RowBox[{"2", RowBox[{"Abs", "[", RowBox[{FractionBox["1", "3"], "-", "1"}], "]"}]}]], ",", "\"\[CurlyPhi]=0 boundary\""}], "}"}], ",", RowBox[{"{", RowBox[{"\"1\"", ",", "\"\[Infinity]\"", ",", "\"All \[Theta] admissible\""}], "}"}], ",", RowBox[{"{", RowBox[{"\"3\"", ",", FractionBox[RowBox[{"3", "+", "1"}], RowBox[{"2", RowBox[{"Abs", "[", RowBox[{"3", "-", "1"}], "]"}]}]], ",", "\"\[CurlyPhi]=0 boundary\""}], "}"}]}], "}"}], ",", RowBox[{"Frame", "->", "All"}]}], "]"}]}], "}"}], "]"}]
}], "Input", CellLabel->"In[15]:="]
}, Open]],

Cell[CellGroupData[{
Cell["5. Perturbation System \[LongDash] Proposition 4.2", "Section"],
Cell["Verify \[Delta]y\[Degree] solves F\:1d62(\[Delta]y,0)=0, center-of-mass, and gauge-fixing.", "Text"],
Cell[BoxData[{
 RowBox[{RowBox[{"\[Alpha]12v", "=", RowBox[{"-", FractionBox["\[Lambda]2", "3"]}]}], ";"}], "\n",
 RowBox[{RowBox[{"\[Alpha]23v", "=", RowBox[{FractionBox["\[Lambda]2", "6"], "-", FractionBox["\[Lambda]1", "2"]}]}], ";"}], "\n",
 RowBox[{RowBox[{"\[Beta]0", "=", FractionBox[RowBox[{"Log", "[", FractionBox["\[Alpha]12v", "\[Alpha]23v"], "]"}], "2"]}], ";"}], "\n",
 RowBox[{RowBox[{"\[Gamma]0", "=", FractionBox[RowBox[{"2", "\[Beta]0"}], RowBox[{"3", SqrtBox["3"]}]]}], ";"}], "\n",
 RowBox[{RowBox[{"\[Delta]y1", "=", RowBox[{"{", RowBox[{"0", ",", RowBox[{"-", "\[Gamma]0"}]}], "}"}]}], ";"}], "\n",
 RowBox[{RowBox[{"\[Delta]y2", "=", RowBox[{"{", RowBox[{RowBox[{"-", "\[Beta]0"}], ",", FractionBox["\[Gamma]0", "2"]}], "}"}]}], ";"}], "\n",
 RowBox[{RowBox[{"\[Delta]y3", "=", RowBox[{"{", RowBox[{"\[Beta]0", ",", FractionBox["\[Gamma]0", "2"]}], "}"}]}], ";"}], "\n",
 RowBox[{RowBox[{"\[Alpha]t12", "=", RowBox[{"Simplify", "[", RowBox[{"Exp", "[", RowBox[{"-", RowBox[{RowBox[{"(", RowBox[{"y2", "-", "y1"}], ")"}], ".", RowBox[{"(", RowBox[{"\[Delta]y2", "-", "\[Delta]y1"}], ")"}]}]}], "]"}], "]"}]}], ";"}], "\n",
 RowBox[{RowBox[{"\[Alpha]t13", "=", RowBox[{"Simplify", "[", RowBox[{"Exp", "[", RowBox[{"-", RowBox[{RowBox[{"(", RowBox[{"y3", "-", "y1"}], ")"}], ".", RowBox[{"(", RowBox[{"\[Delta]y3", "-", "\[Delta]y1"}], ")"}]}]}], "]"}], "]"}]}], ";"}], "\n",
 RowBox[{RowBox[{"\[Chi]0", "=", "\[Alpha]12v"}], ";"}], "\n",
 RowBox[{RowBox[{"\[Alpha]t23", "=", RowBox[{"Simplify", "[", RowBox[{"Exp", "[", RowBox[{"-", RowBox[{RowBox[{"(", RowBox[{"y3", "-", "y2"}], ")"}], ".", RowBox[{"(", RowBox[{"\[Delta]y3", "-", "\[Delta]y2"}], ")"}]}]}], "]"}], "]"}]}], ";"}], "\n",
 RowBox[{RowBox[{"F1", "=", RowBox[{"Simplify", "[", RowBox[{RowBox[{"Hv", ".", "y1"}], "-", RowBox[{"(", RowBox[{RowBox[{"\[Alpha]t12", " ", "\[Chi]0", " ", RowBox[{"(", RowBox[{"y2", "-", "y1"}], ")"}]}], "+", RowBox[{"\[Alpha]t13", " ", "\[Chi]0", " ", RowBox[{"(", RowBox[{"y3", "-", "y1"}], ")"}]}]}], ")"}]}], "]"}]}], ";"}], "\n",
 RowBox[{RowBox[{"F2", "=", RowBox[{"Simplify", "[", RowBox[{RowBox[{"Hv", ".", "y2"}], "-", RowBox[{"(", RowBox[{RowBox[{"\[Alpha]t12", " ", "\[Chi]0", " ", RowBox[{"(", RowBox[{"y1", "-", "y2"}], ")"}]}], "+", RowBox[{"\[Alpha]t23", " ", "\[Chi]0", " ", RowBox[{"(", RowBox[{"y3", "-", "y2"}], ")"}]}]}], ")"}]}], "]"}]}], ";"}], "\n",
 RowBox[{RowBox[{"F3", "=", RowBox[{"Simplify", "[", RowBox[{RowBox[{"Hv", ".", "y3"}], "-", RowBox[{"(", RowBox[{RowBox[{"\[Alpha]t13", " ", "\[Chi]0", " ", RowBox[{"(", RowBox[{"y1", "-", "y3"}], ")"}]}], "+", RowBox[{"\[Alpha]t23", " ", "\[Chi]0", " ", RowBox[{"(", RowBox[{"y2", "-", "y3"}], ")"}]}]}], ")"}]}], "]"}]}], ";"}], "\n",
 RowBox[{"Grid", "[", RowBox[{RowBox[{"{", RowBox[{RowBox[{"{", RowBox[{RowBox[{"Style", "[", RowBox[{"\"Item\"", ",", "Bold"}], "]"}], ",", RowBox[{"Style", "[", RowBox[{"\"Value\"", ",", "Bold"}], "]"}], ",", RowBox[{"Style", "[", RowBox[{"\"Expected\"", ",", "Bold"}], "]"}]}], "}"}], ",", RowBox[{"{", RowBox[{"\"\[Sum]\[Delta]y\"", ",", RowBox[{"Simplify", "[", RowBox[{"\[Delta]y1", "+", "\[Delta]y2", "+", "\[Delta]y3"}], "]"}], ",", RowBox[{"{", RowBox[{"0", ",", "0"}], "}"}]}], "}"}], ",", RowBox[{"{", RowBox[{"\"\[Delta]y1\[CenterDot]r1 (G1)\"", ",", RowBox[{"\[Delta]y1", "[[", "1", "]]"}], ",", "0"}], "}"}], ",", RowBox[{"{", RowBox[{"\"\[Delta]y3-\[Delta]y2 (G2)\"", ",", RowBox[{"Simplify", "[", RowBox[{"\[Delta]y3", "-", "\[Delta]y2"}], "]"}], ",", "\"{*,0}\""}], "}"}], ",", RowBox[{"{", RowBox[{"\"\[Alpha]~12\"", ",", "\[Alpha]t12", ",", "1"}], "}"}], ",", RowBox[{"{", RowBox[{"\"\[Alpha]~13\"", ",", "\[Alpha]t13", ",", "1"}], "}"}], ",", RowBox[{"{", RowBox[{"\"F1\"", ",", "F1", ",", RowBox[{"{", RowBox[{"0", ",", "0"}], "}"}]}], "}"}], ",", RowBox[{"{", RowBox[{"\"F2\"", ",", "F2", ",", RowBox[{"{", RowBox[{"0", ",", "0"}], "}"}]}], "}"}], ",", RowBox[{"{", RowBox[{"\"F3\"", ",", "F3", ",", RowBox[{"{", RowBox[{"0", ",", "0"}], "}"}]}], "}"}]}], "}"}], ",", RowBox[{"Frame", "->", "All"}], ",", RowBox[{"Spacings", "->", RowBox[{"{", RowBox[{"2", ",", "1"}], "}"}]}]}], "]"}]
}], "Input", CellLabel->"In[18]:="]
