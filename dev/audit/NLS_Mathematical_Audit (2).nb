Cell[CellGroupData[{
Cell["6. Kernel Analysis \[LongDash] Proposition 4.3", "Section"],
Cell["Compute kernel dimension and verify translation/rotation modes.", "Text"],
Cell[BoxData[{
 RowBox[{RowBox[{"d12", "=", RowBox[{"y2", "-", "y1"}]}], ";", RowBox[{"d13", "=", RowBox[{"y3", "-", "y1"}]}], ";", RowBox[{"d23", "=", RowBox[{"y3", "-", "y2"}]}], ";"}], "\n",
 RowBox[{RowBox[{"Amat", "=", RowBox[{"{", RowBox[{RowBox[{"Join", "[", RowBox[{RowBox[{"-", "d12"}], ",", "d12", ",", RowBox[{"{", RowBox[{"0", ",", "0"}], "}"}]}], "]"}], ",", RowBox[{"Join", "[", RowBox[{RowBox[{"-", "d13"}], ",", RowBox[{"{", RowBox[{"0", ",", "0"}], "}"}], ",", "d13"}], "]"}], ",", RowBox[{"Join", "[", RowBox[{RowBox[{"{", RowBox[{"0", ",", "0"}], "}"}], ",", RowBox[{"-", "d23"}], ",", "d23"}], "]"}]}], "}"}]}], ";"}], "\n",
 RowBox[{RowBox[{"wrot", "=", RowBox[{"Join", "@@", RowBox[{"(", RowBox[{RowBox[{RowBox[{"(", RowBox[{RowBox[{"D", "[", RowBox[{RowBox[{RowBox[{"R\[Theta]", "[", "\[Theta]", "]"}], ".", "#"}], ",", "\[Theta]"}], "]"}], "/.", RowBox[{"\[Theta]", "->", "0"}]}], ")"}], "&"}], "/@", RowBox[{"{", RowBox[{"y1", ",", "y2", ",", "y3"}], "}"}]}], ")"}]}]}], ";"}], "\n",
 RowBox[{"Column", "[", RowBox[{"{", RowBox[{RowBox[{"Row", "[", RowBox[{"{", RowBox[{"\"Rank(A) = \"", ",", RowBox[{"MatrixRank", "[", "Amat", "]"}], ",", "\"  \[RightArrow]  dim(\[CapitalOmega]) = 6\[Minus]2 = 4\""}], "}"}], "]"}], ",", RowBox[{"Style", "[", RowBox[{"\"Kernel basis:\"", ",", "Bold"}], "]"}], ",", RowBox[{RowBox[{"NullSpace", "[", "Amat", "]"}], "//", "MatrixForm"}], ",", RowBox[{"Row", "[", RowBox[{"{", RowBox[{"\"Translation (1,0,1,0,1,0)\[CenterDot]A = \"", ",", RowBox[{"Amat", ".", RowBox[{"{", RowBox[{"1", ",", "0", ",", "1", ",", "0", ",", "1", ",", "0"}], "}"}]}]}], "}"}], "]"}], ",", RowBox[{"Row", "[", RowBox[{"{", RowBox[{"\"Rotation w_rot\[CenterDot]A = \"", ",", RowBox[{"Simplify", "[", RowBox[{"Amat", ".", "wrot"}], "]"}], ",", "\"  \[Checkmark]\""}], "}"}], "]"}]}], "}"}], "]"}]
}], "Input", CellLabel->"In[33]:="]
}, Open]],

Cell[CellGroupData[{
Cell["7. Equivariance \[LongDash] Remark 5.4", "Section"],
Cell[BoxData[{
 RowBox[{"Column", "[", RowBox[{"{", RowBox[{RowBox[{"Style", "[", RowBox[{"\"Isotropic (\[Lambda]1=\[Lambda]2=\[Lambda]):\"", ",", "Bold"}], "]"}], ",", RowBox[{"Row", "[", RowBox[{"{", RowBox[{"\"[R(\[Omega]), \[Lambda]I] = \"", ",", RowBox[{"Simplify", "[", RowBox[{RowBox[{RowBox[{"R\[Theta]", "[", "\[Omega]", "]"}], ".", RowBox[{"(", RowBox[{"\[Lambda]", " ", RowBox[{"IdentityMatrix", "[", "2", "]"}]}], ")"}]}], "-", RowBox[{RowBox[{"(", RowBox[{"\[Lambda]", " ", RowBox[{"IdentityMatrix", "[", "2", "]"}]}], ")"}], ".", RowBox[{"R\[Theta]", "[", "\[Omega]", "]"}]}]}], "]"}], ",", "\"  \[DoubleLeftRightArrow]  Full equivariance\""}], "}"}], "]"}], ",", RowBox[{"Style", "[", RowBox[{"\"\nAnisotropic (\[Mu]=4, \[Omega]=0.3):\"", ",", "Bold"}], "]"}], ",", RowBox[{"Row", "[", RowBox[{"{", RowBox[{"\"[R(\[Omega]), H_V] = \"", ",", RowBox[{"N", "[", RowBox[{RowBox[{RowBox[{RowBox[{"R\[Theta]", "[", "0.3", "]"}], ".", RowBox[{"DiagonalMatrix", "[", RowBox[{"{", RowBox[{RowBox[{"-", "1"}], ",", RowBox[{"-", "4"}]}], "}"}], "]"}]}], "-", RowBox[{RowBox[{"DiagonalMatrix", "[", RowBox[{"{", RowBox[{RowBox[{"-", "1"}], ",", RowBox[{"-", "4"}]}], "}"}], "]"}], ".", RowBox[{"R\[Theta]", "[", "0.3", "]"}]}]}], ",", "4"}], "]"}], ",", "\"  \[NotEqual] 0\""}], "}"}], "]"}]}], "}"}], "]"}]
